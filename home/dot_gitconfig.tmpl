# This is Git's per-user configuration file.
[core]
	editor = code --wait
	autocrlf = false
	sshCommand = {{ if or (eq .chezmoi.os "windows") (and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | contains "WSL")) }}ssh.exe{{ else }}ssh{{ end }}

[help]
	autocorrect = 1

[alias]
	amend = commit --amend
	append = commit --amend --no-edit
	# checkout or create new branch
	ck = "!f() { git checkout $1 2>/dev/null || git checkout -b $1; }; f"
	cnv = commit -n -m
	# count the number of files changed in the current branch compared to main
	count = !git diff --name-only main... | wc -l
	dd = !git --no-pager diff
	discard = checkout -- .
	last = log -1 HEAD --stat
	logf = !git log --pretty=format:"%C(magenta)%h%Creset -%C(red)%d%Creset %s %C(dim green)(%cr) [%an]" --abbrev-commit -30
	main = checkout main
	# clean up merged branches using "main" as default
	purge = "!f() { git branch --merged ${1-main} | grep -v " ${1-main}$" | xargs -r git branch -d; }; f"
	st = status -sb
	# pull rebase remote main
	sync = !git pull origin main --rebase
	unstage = reset HEAD --
	# push and set up origin for branch
	up = !git push -u origin `git branch --show-current`
	upt = !git push origin --tags

	# save the current state of the working directory and index to the stash
	save = !git add -A && git commit -m 'SAVEPOINT'
	# undo the last commit, but keep the changes available
	undo = reset HEAD~1 --mixed
	# interactive rebase against last commit on main
	rebase-main = "!f() { git rebase -i $(git merge-base HEAD main); }; f"

[init]
	defaultBranch = main
