{{ if and (eq .chezmoi.os "windows") (eq .env "dev_computer") -}}
# Install Visual Studio Code on Windows via winget.

$ErrorActionPreference = "Stop"

if (Get-Command code -ErrorAction SilentlyContinue) {
    Write-Host "==> VS Code already installed, skipping."
    exit 0
}

Write-Host "==> Installing VS Code..." -ForegroundColor Cyan
winget install --id Microsoft.VisualStudioCode --silent --accept-package-agreements --accept-source-agreements

Write-Host "  VS Code installed." -ForegroundColor Green
{{ end -}}
