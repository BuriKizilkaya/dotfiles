{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Install zsh as default shell and set up plugins (no oh-my-zsh).
# Runs on change (chezmoi tracks the hash of this file).
# hash: {{ include ".chezmoiscripts/run_before_01_install-zsh.sh.tmpl" | sha256sum }}

set -euo pipefail

echo "==> Setting up zsh..."

# Switch default shell to zsh
current_user="${USER:-$(whoami)}"
ZSH_PATH="$(command -v zsh)"
echo "  Switching default shell to zsh..."
if ! grep -qxF "$ZSH_PATH" /etc/shells; then
    echo "  Adding $ZSH_PATH to /etc/shells..."
    echo "$ZSH_PATH" | sudo tee -a /etc/shells > /dev/null
fi
sudo chsh -s "$ZSH_PATH" "$current_user"

echo "  Installing zsh plugins..."
ZSH_PLUGINS="$HOME/.zsh/plugins"
mkdir -p "$ZSH_PLUGINS"

if [ ! -d "$ZSH_PLUGINS/zsh-syntax-highlighting" ]; then
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$ZSH_PLUGINS/zsh-syntax-highlighting"
else
    git -C "$ZSH_PLUGINS/zsh-syntax-highlighting" pull --ff-only
fi

if [ ! -d "$ZSH_PLUGINS/zsh-autosuggestions" ]; then
    git clone https://github.com/zsh-users/zsh-autosuggestions.git "$ZSH_PLUGINS/zsh-autosuggestions"
else
    git -C "$ZSH_PLUGINS/zsh-autosuggestions" pull --ff-only
fi

echo "  zsh setup complete."
{{ end -}}
