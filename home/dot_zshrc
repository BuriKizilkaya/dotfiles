# zsh completion (provides git tab-completion and all other zsh completions)
autoload -Uz compinit && compinit

# zsh plugins (installed to ~/.zsh/plugins by chezmoi script)
ZSH_PLUGINS="$HOME/.zsh/plugins"
source "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# Starship
eval "$(starship init zsh)"

# Add ~/.local/bin to PATH for user-installed tools
export PATH="$HOME/.local/bin:$PATH"

# Start Docker daemon automatically when logging in if not running.
DOCKERRUNNING=`ps aux | grep dockerd | grep -v grep`
DOCKER_CMD_EXISTS=`command -v docker`
if [ "$(uname)" != "Darwin" ] && [ -z "$DOCKERRUNNING" ] && [ -n "$DOCKER_CMD_EXISTS" ]; then
  echo "Starting Docker daemon..."
  sudo dockerd > /dev/null 2>&1 &
  disown
fi

# Source all profile files
for file in $HOME/.profile*; do
  source "$file"
done

# SSH Agent 1password
if [ -S "$HOME/.1password/agent.sock" ]; then
  export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
fi

# mise
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi
