# Add ~/.local/bin to PATH for user-installed tools
export PATH="$HOME/.local/bin:$PATH"

# mise (activate early so mise-managed tools are on PATH for everything below)
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

# zsh completion (provides git tab-completion and all other zsh completions)
autoload -Uz compinit && compinit

# Case-insensitive tab completion (matches lowercase, uppercase, camelCase, etc.)
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# Menu selection: arrow keys to navigate completions visually (like oh-my-zsh)
zstyle ':completion:*' menu select

# Key bindings for menu navigation (fixes Ctrl+Arrow showing ;5d)
bindkey '\e[1;5D' vi-backward-word  # Ctrl+Left
bindkey '\e[1;5C' vi-forward-word   # Ctrl+Right
bindkey '\e[1;5A' up-line-or-history  # Ctrl+Up
bindkey '\e[1;5B' down-line-or-history  # Ctrl+Down

# zsh plugins (installed to ~/.zsh/plugins by chezmoi script)
ZSH_PLUGINS="$HOME/.zsh/plugins"
source "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# Starship
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

# Start Docker daemon automatically when logging in if not running.
DOCKERRUNNING=`ps aux | grep dockerd | grep -v grep`
DOCKER_CMD_EXISTS=`command -v docker`
if [ "$(uname)" != "Darwin" ] && [ -z "$DOCKERRUNNING" ] && [ -n "$DOCKER_CMD_EXISTS" ]; then
  echo "Starting Docker daemon..."
  sudo dockerd > /dev/null 2>&1 &
  disown
fi

# Source all profile files
for file in $HOME/.profile*; do
  source "$file"
done

# SSH Agent 1password
if [ -S "$HOME/.1password/agent.sock" ]; then
  export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
fi

